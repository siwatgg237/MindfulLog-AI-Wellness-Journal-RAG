# ====================================
# Python .gitignore
# ====================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables (NEVER commit secrets)
.env

# ChromaDB local persistence
chroma_db/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Jupyter Notebook
.ipynb_checkpoints/

# pytest / coverage
.pytest_cache/
htmlcov/
.coverage

# mypy
.mypy_cache/
